# Application
APP_NAME=service-request-chatbot-api
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Database (async SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/service_request_chatbot

# Redis
REDIS_URL=redis://localhost:6379/0

# External integrations (placeholders — wire in production)
SERVICE_REQUEST_API_BASE_URL=
LEASE_TENANT_API_BASE_URL=
FILE_UPLOAD_API_BASE_URL=

# Platform service-to-service auth (Cenomi platform login)
# PLATFORM_AUTH_BASE_URL defaults to SERVICE_REQUEST_API_BASE_URL when blank
PLATFORM_AUTH_BASE_URL=
PLATFORM_INTERNAL_API_TOKEN=
PLATFORM_LOGIN_EMAIL=

# Security (replace in production)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# LLM / AI (required in production)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_CONFIDENCE_THRESHOLD=0.6
