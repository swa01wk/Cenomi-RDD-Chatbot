# Public API base (browser calls FastAPI)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NOTE: NEXT_PUBLIC_API_V1_PREFIX is NOT used by the chat client.
# The chat route has no /v1 prefix: /api/chat/service-request
# The upload route uses the /api/v1 prefix: /api/v1/upload
# This variable is kept as documentation only; the client hardcodes /api.
NEXT_PUBLIC_API_V1_PREFIX=
